{
  "name": "vantage-studio",
  "private": true,
  "version": "0.0.0",
  "description": "Web admin for Apache SkyWalking's runtime-rule hot-update (MAL/LAL).",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "license-headers": "node scripts/check-license-headers.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2"
    ]
  }
}

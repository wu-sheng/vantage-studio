{
  "name": "vantage-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Web admin for Apache SkyWalking's runtime-rule hot-update (MAL/LAL).",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "license-headers": "docker run --rm -v $PWD:/github/workspace ghcr.io/apache/skywalking-eyes:0.7.0 -c /github/workspace/.licenserc.yaml header check",
    "license-headers:fix": "docker run --rm -v $PWD:/github/workspace ghcr.io/apache/skywalking-eyes:0.7.0 -c /github/workspace/.licenserc.yaml header fix"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "vite": "^6.0.3"
    }
  }
}
